# ==========================================
# AUSTA Care Platform — Environment Variables
# ==========================================
# Copy this file to .env and fill in real values.
# NEVER commit .env files — they contain secrets.
#
# For local development, run:
#   bash scripts/generate-dev-secrets.sh
#
# ==========================================

# ----- Database (PostgreSQL) -----
DATABASE_URL=postgresql://austa_user:CHANGE_ME@localhost:5432/austa_care
POSTGRES_USER=austa_user
POSTGRES_PASSWORD=CHANGE_ME_USE_SECURE_RANDOM
POSTGRES_DB=austa_care

# ----- Redis -----
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME_USE_SECURE_RANDOM

# ----- JWT -----
JWT_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM
JWT_REFRESH_SECRET=CHANGE_ME_USE_64_CHAR_RANDOM

# ----- WhatsApp (Z-API — current provider) -----
WHATSAPP_PROVIDER=z-api
WHATSAPP_API_URL=https://api.z-api.io
WHATSAPP_INSTANCE_ID=CHANGE_ME
WHATSAPP_TOKEN=CHANGE_ME

# ----- OpenAI -----
OPENAI_API_KEY=sk-CHANGE_ME

# ----- AWS -----
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME

# ----- Tasy ERP -----
TASY_API_URL=https://CHANGE_ME.tasy.com.br/api
TASY_CLIENT_ID=CHANGE_ME
TASY_CLIENT_SECRET=CHANGE_ME

# ----- Audit -----
AUDIT_ENCRYPTION_KEY=CHANGE_ME_USE_32_BYTE_HEX

# ----- MongoDB -----
MONGO_INITDB_ROOT_USERNAME=austa
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_USE_SECURE_RANDOM
MONGO_INITDB_DATABASE=austa_care

# ----- MinIO -----
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_USE_SECURE_RANDOM

# ----- Grafana -----
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME_USE_SECURE_RANDOM

# ----- PGAdmin -----
PGADMIN_DEFAULT_EMAIL=admin@austa.com
PGADMIN_DEFAULT_PASSWORD=CHANGE_ME_USE_SECURE_RANDOM

# ----- App -----
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug
