# =============================================================================
# AUSTA Care Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in real values for your environment.
#   cp .env.example .env
#
# NEVER commit .env to version control. It is gitignored by default.
#
# Environment presets:
#   Development (local):  use scripts/generate-dev-secrets.sh to auto‑generate
#   Staging / Production: values come from AWS Secrets Manager at runtime
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# PostgreSQL (Prisma) — used by backend and postgres container
# ---------------------------------------------------------------------------
POSTGRES_USER=austa_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=austa_care
DATABASE_URL=postgresql://austa_user:change_me_in_production@postgres:5432/austa_care?schema=public

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379
REDIS_CLUSTER_ENABLED=false
REDIS_CLUSTER_NODES=

# ---------------------------------------------------------------------------
# MongoDB
# ---------------------------------------------------------------------------
MONGODB_URI=mongodb://austa:***@mongodb:27017
MONGODB_DATABASE=austa_care
MONGO_INITDB_ROOT_USERNAME=austa
MONGO_INITDB_ROOT_PASSWORD=change_me_in_production
MONGO_INITDB_DATABASE=austa_care

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=austa-care-platform
KAFKA_SSL_ENABLED=false
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_at_least_32_characters_long
JWT_EXPIRY=24h
JWT_REFRESH_SECRET=change_me_in_production_at_least_32_characters_long
JWT_REFRESH_EXPIRY=7d

# ---------------------------------------------------------------------------
# Encryption
# ---------------------------------------------------------------------------
ENCRYPTION_KEY=change_me_in_production_at_least_32_characters_long
ENCRYPTION_ALGORITHM=aes-256-gcm

# ---------------------------------------------------------------------------
# WhatsApp Z-API Integration
# ---------------------------------------------------------------------------
ZAPI_BASE_URL=https://api.z-api.io
ZAPI_INSTANCE_ID=your_zapi_instance_id_here
ZAPI_TOKEN=your_zapi_token_here
ZAPI_WEBHOOK_SECRET=your_zapi_webhook_secret_here_min_32_chars
ZAPI_WEBHOOK_VERIFY_TOKEN=your_zapi_webhook_verify_token_here
ZAPI_RATE_LIMIT_REQUESTS=20
ZAPI_RATE_LIMIT_WINDOW_MS=60000
ZAPI_RETRY_ATTEMPTS=3
ZAPI_RETRY_DELAY_MS=1000

# ---------------------------------------------------------------------------
# OpenAI
# ---------------------------------------------------------------------------
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=2048

# ---------------------------------------------------------------------------
# Tasy EHR Integration
# ---------------------------------------------------------------------------
TASY_API_URL=https://your-tasy-instance.example.com/api
TASY_API_KEY=your_tasy_api_key_here
TASY_API_SECRET=your_tasy_api_secret_here_min_32_chars
TASY_CLIENT_ID=your_tasy_oauth_client_id_here
TASY_CLIENT_SECRET=your_tasy_oauth_client_secret_here_min_32_chars

# ---------------------------------------------------------------------------
# FHIR Server
# ---------------------------------------------------------------------------
FHIR_BASE_URL=http://localhost:8090/fhir
FHIR_VERSION=R4

# ---------------------------------------------------------------------------
# AWS (required for staging / production)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=sa-east-1
AWS_S3_BUCKET=your-s3-bucket-name-here
AWS_SECRETS_MANAGER_REGION=sa-east-1

# ---------------------------------------------------------------------------
# CORS
# ---------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:5173

# ---------------------------------------------------------------------------
# Rate Limiting
# ---------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ---------------------------------------------------------------------------
# Health Check
# ---------------------------------------------------------------------------
HEALTH_CHECK_INTERVAL=30000

# ---------------------------------------------------------------------------
# Feature Flags
# ---------------------------------------------------------------------------
ENABLE_GAMIFICATION=true
ENABLE_ML_MODELS=true
ENABLE_FHIR_GATEWAY=false

# ---------------------------------------------------------------------------
# WebSocket
# ---------------------------------------------------------------------------
WEBSOCKET_PATH=/socket.io
WEBSOCKET_PING_TIMEOUT=60000
WEBSOCKET_PING_INTERVAL=25000

# ---------------------------------------------------------------------------
# File Upload
# ---------------------------------------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads

# ---------------------------------------------------------------------------
# Admin Tools (dev only) — pgAdmin
# ---------------------------------------------------------------------------
PGADMIN_DEFAULT_EMAIL=admin@austa.com
PGADMIN_DEFAULT_PASSWORD=change_me_in_production

# ---------------------------------------------------------------------------
# Grafana (dev / staging)
# ---------------------------------------------------------------------------
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=change_me_in_production

# ---------------------------------------------------------------------------
# MinIO (S3-compatible local storage)
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change_me_in_production
